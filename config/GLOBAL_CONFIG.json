{
    "PROJECT_NAME": "M3m01r5",
    "PROJECT_FOLDER": "M3m01r5",
    "PROJECT_DESCRIPTION": "Personal journalling and memoir archiving utility with drop-in categorical descriptors.",
    "AUTHOR": "Daniel Austin <the.potato.gnome@gmail.com>",
    "VERSION": "0.1.0",
    "MAIN_ENTRY_POINT": "src/M3m01r5/main.py",
    "ROOT_MODES": {
        "LOGS": "project",
        "TEST_LOGS": "project",
        "CONFIG": "project",
        "TEST_CONFIG": "project"
    },
    "PATHS": {
