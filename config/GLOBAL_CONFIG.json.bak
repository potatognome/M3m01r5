{
    "PROJECT_NAME": "M3m01r5",
    "PROJECT_FOLDER": "M3m01r5",
    "PROJECT_DESCRIPTION": "Personal journalling and memoir archiving utility with drop-in categorical descriptors.",
    "AUTHOR": "Daniel Austin <the.potato.gnome@gmail.com>",
    "VERSION": "0.1.0",
    "MAIN_ENTRY_POINT": "src/M3m01r5/main.py",
    "ROOT_MODES": {
        "LOGS": "project",
        "TEST_LOGS": "project",
        "CONFIG": "project",
        "TEST_CONFIG": "project",
        "LOG_PATHS": "workspace",
        "TESTS_LOGS": "workspace",
        "TESTS_CONFIG": "project",
        "OUTPUT_DATA": "workspace",
        "INPUT_DATA": "workspace",
        "TESTS_INPUTS": "workspace",
        "TESTS_OUTPUTS": "workspace"
    },
    "PATHS": {
        "CONFIG": "config/",
        "LOGS": "logFiles/",
        "DATA": "data/entries/",
        "TESTS_LOGS": "tests/testOutputLogs/",
        "LOG_PATHS": ".logs/M3m01r5/",
        "TESTS_CONFIG": ".tests_config/",
        "OUTPUT_DATA": ".projects_data/M3m01r5/",
        "INPUT_DATA": ".projects_data/input_data/",
        "TESTS_INPUTS": ".tests_data/",
        "TESTS_OUTPUTS": ".tests_data/output/"
    },
    "CONFIG_FILES": {
        "GLOBAL_CONFIG": "config/GLOBAL_CONFIG.json",
        "M3M01R5_CONFIG": "config/m3m01r5_config.yaml"
    },
    "LOG_FILES": {
        "SESSION": "logFiles/SESSION.log",
        "MASTER": "logFiles/MASTER.log",
        "ERROR": "logFiles/ERROR.log",
        "RUNTIME": "M3m01r5_RUNTIME.log",
        "TRY": "M3m01r5_TRY.log",
        "INIT": "M3m01r5_INIT.log",
        "FS": "M3m01r5_FS.log",
        "CONFIG_READ": "M3m01r5_CONFIG_READ.log"
    },
    "DISPLAY": {
        "COLOUR_ENABLED": true,
        "LOGGING": "verbose"
    },
    "INFO": {
        "PROJECT_FOLDER": "/Applications/M3m01r5/",
        "PROJECT_DESCRIPTION": "{PROJECT_DESCRIPTION}",
        "AUTHOR": "{AUTHOR}",
        "MAIN_ENTRY_POINT": "M3m01r5.main:main"
    },
    "ROOTS": {
        "WORKSPACE": "C:\\Repository\\Daniel\\dev_local",
        "PROJECT": "C:\\Repository\\Daniel\\dev_local\\Applications\\M3m01r5"
    },
    "SHARED_CONFIG": {
        "ENABLED": true,
        "PATH": "GLOBAL_SHARED.d/",
        "FILES": {
            "COLOURS": "COLOURS.json",
            "BORDER_PATTERNS": "BORDER_PATTERNS.json",
            "TESTS_OPTIONS": "TESTS_OPTIONS.json",
            "TIME_STAMP_OPTIONS": "TIME_STAMP_OPTIONS.json"
        }
    },
    "ALT_CONFIG": {
        "ENABLED": false,
        "PATH": "",
        "FILES": {
            "COLOURS": "",
            "BORDER_PATTERNS": "",
            "TESTS_OPTIONS": "",
            "TIME_STAMP_OPTIONS": ""
        }
    },
    "LOG_CATEGORIES": {
        "default": [
            "MASTER",
            "SESSION"
        ],
        "runtime": [
            "MASTER",
            "SESSION",
            "RUNTIME"
        ],
        "error": [
            "MASTER",
            "SESSION",
            "ERROR"
        ],
        "init": [
            "MASTER",
            "SESSION",
            "INIT"
        ],
        "fs": [
            "MASTER",
            "SESSION",
            "FS"
        ],
        "config_read": [
            "MASTER",
            "SESSION",
            "CONFIG_READ"
        ],
        "try": [
            "MASTER",
            "SESSION",
            "TRY"
        ],
        "all": [
            "MASTER",
            "SESSION",
            "RUNTIME",
            "TRY",
            "INIT",
            "FS",
            "CONFIG_READ",
            "ERROR"
        ]
    }
}
